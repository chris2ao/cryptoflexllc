{
  "PreToolUse": [
    {
      "matcher": "Edit|Write",
      "script": "bash \"$HOME/.claude/hooks/dispatch.sh\" file-guard",
      "description": "dispatch.sh\" file-guard",
      "timeout": 5000
    },
    {
      "matcher": "Skill",
      "script": "ccstatusline --hook",
      "description": "ccstatusline --hook",
      "timeout": 5000
    }
  ],
  "PostToolUse": [
    {
      "matcher": "Edit|Write|Bash",
      "script": "bash \"$HOME/.claude/hooks/dispatch.sh\" log-activity",
      "description": "dispatch.sh\" log-activity",
      "timeout": 5000
    },
    {
      "matcher": "Edit|Write|Bash|Read|Grep|Glob",
      "script": "bash \"$HOME/.claude/hooks/dispatch.sh\" observe-homunculus",
      "description": "dispatch.sh\" observe-homunculus",
      "timeout": 5000
    },
    {
      "matcher": "Edit|Write|Bash|Agent|mcp__memory__create_entities|mcp__memory__create_relations|mcp__memory__delete_entities|mcp__memory__add_observations|mcp__obsidian__create_vault_file|mcp__obsidian__patch_vault_file|mcp__github__create_pull_request|mcp__github__create_issue|mcp__github__push_files",
      "script": "bash \"$HOME/.claude/hooks/dispatch.sh\" memory-nudge",
      "description": "dispatch.sh\" memory-nudge",
      "timeout": 5000
    },
    {
      "matcher": "Edit|Write",
      "script": "bash \"$HOME/.claude/hooks/dispatch.sh\" kg-update-detect",
      "description": "dispatch.sh\" kg-update-detect",
      "timeout": 5000
    }
  ],
  "Stop": [
    {
      "matcher": "",
      "script": "bash \"$HOME/.claude/hooks/dispatch.sh\" prompt-notify",
      "description": "dispatch.sh\" prompt-notify",
      "timeout": 3000
    },
    {
      "matcher": "",
      "script": "bash \"$HOME/.claude/hooks/dispatch.sh\" memory-checkpoint",
      "description": "dispatch.sh\" memory-checkpoint",
      "timeout": 5000
    }
  ],
  "SessionEnd": [
    {
      "matcher": "",
      "script": "bash \"$HOME/.claude/hooks/dispatch.sh\" save-session",
      "description": "dispatch.sh\" save-session",
      "timeout": 10000
    }
  ],
  "UserPromptSubmit": [
    {
      "matcher": "",
      "script": "ccstatusline --hook",
      "description": "ccstatusline --hook",
      "timeout": 5000
    }
  ]
}