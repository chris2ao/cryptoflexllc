{
  "PreToolUse": [
    {
      "matcher": "Edit|Write",
      "script": "file-guard",
      "description": "Block edits to sensitive files (.env, .pem, credentials)"
    },
    {
      "matcher": "Skill",
      "script": "ccstatusline",
      "description": "Run ccstatusline"
    }
  ],
  "PostToolUse": [
    {
      "matcher": "Edit|Write|Bash",
      "script": "log-activity",
      "description": "Log tool usage activity to session log",
      "timeout": 5000
    },
    {
      "matcher": "Edit|Write|Bash|Read|Grep|Glob",
      "script": "observe-homunculus",
      "description": "Capture behavioral observations for the Homunculus layer",
      "timeout": 5000
    },
    {
      "matcher": "Edit|Write|Bash|Agent|mcp__memory__create_entities|mcp__memory__create_relations|mcp__memory__delete_entities|mcp__memory__add_observations|mcp__obsidian__create_vault_file|mcp__obsidian__patch_vault_file|mcp__github__create_pull_request|mcp__github__create_issue|mcp__github__push_files",
      "script": "memory-nudge",
      "description": "Nudge to save context to vector memory after significant tool use",
      "timeout": 5000
    },
    {
      "matcher": "Edit|Write",
      "script": "kg-update-detect",
      "description": "Detect knowledge graph changes after file edits",
      "timeout": 5000
    }
  ],
  "Stop": [
    {
      "matcher": "",
      "script": "prompt-notify",
      "description": "Send macOS notification when Claude stops and waits for input",
      "timeout": 3000
    },
    {
      "matcher": "",
      "script": "memory-checkpoint",
      "description": "Structured memory capture checklist on session end",
      "timeout": 5000
    }
  ],
  "SessionEnd": [
    {
      "matcher": "",
      "script": "save-session",
      "description": "Archive session transcript to .claude/session_archive/",
      "timeout": 10000
    }
  ],
  "UserPromptSubmit": [
    {
      "matcher": "",
      "script": "ccstatusline",
      "description": "Run ccstatusline"
    }
  ]
}
